generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  name         String?
  records      StudyRecord[]
  goals        Goal[]
  categories   Category[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model StudyRecord {
  id              Int      @id @default(autoincrement())
  userId          Int
  goalId          Int?
  date            DateTime
  durationMinutes Int
  content         String
  user            User     @relation(fields: [userId], references: [id])
  goal            Goal?    @relation(fields: [goalId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Goal {
  id              Int           @id @default(autoincrement())
  userId          Int
  title           String
  categoryId      Int?
  category        Category?     @relation(fields: [categoryId], references: [id])
  targetMinutes   Int
  deadline        DateTime
  isCompleted     Boolean       @default(false)
  user            User          @relation(fields: [userId], references: [id])
  records         StudyRecord[]
  todos           Todo[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Category {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  user      User     @relation(fields: [userId], references: [id])
  goals     Goal[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

model Todo {
  id          Int      @id @default(autoincrement())
  goalId      Int
  content     String
  isCompleted Boolean  @default(false)
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
